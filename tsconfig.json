{
  "extends": "@fingerprintjs/tsconfig-dx-team/tsconfig.json",
  "compilerOptions": {
    "outDir": "dist/src",
    "module": "es6",
    "moduleResolution": "node",
    "target": "es2022",
    "allowImportingTsExtensions": true,
  },

  "files": ["./src/index.ts"],
  "include": [".github/**/*.ts"],
  "exclude": ["dist", "node_modules", "**/*.test.ts"],
}
