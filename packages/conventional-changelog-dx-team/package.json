{
  "name": "@fingerprintjs/conventional-changelog-dx-team",
  "version": "0.1.0",
  "private": false,
  "description": "Custom conventional changelog preset for semantic-release",
  "repository": {
    "type": "git",
    "url": "https://github.com/fingerprintjs/dx-team-toolkit"
